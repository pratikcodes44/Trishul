# =====================================================
# Project Trishul - Environment Configuration
# =====================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =====================================================

# Discord Webhook for vulnerability alerts
# Create one at: Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# Telegram Bot (Optional - Alternative to Discord)
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Ollama AI Configuration (for WAF evasion tactics)
# Default points to local Ollama instance
OLLAMA_API_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=xploiter/bugbounty-ai
